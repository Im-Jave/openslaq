{
  "name": "@openslaq/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --port 3007",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsgo --noEmit",
    "test": "NODE_OPTIONS='--require ./jest-bun-resolver.js' jest",
    "test:watch": "NODE_OPTIONS='--require ./jest-bun-resolver.js' jest --watch",
    "test:coverage": "NODE_OPTIONS='--require ./jest-bun-resolver.js' jest --coverage",
    "e2e:prebuild": "expo prebuild --platform ios --clean",
    "e2e:build": "detox build --configuration ios.sim.release",
    "e2e:test": "detox test --configuration ios.sim.release"
  },
  "dependencies": {
    "@openslaq/client-core": "workspace:*",
    "@openslaq/shared": "workspace:*",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "^8.0.8",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "hono": "^4.7.4",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-syntax-highlighter": "^2.1.0",
    "rn-emoji-keyboard": "^1.7.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@jest/reporters": "^29.7.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "detox": "^20.29.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jose": "^6.0.0",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.3"
  }
}
