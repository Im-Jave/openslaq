{
  "expo": {
    "name": "OpenSlaq",
    "slug": "openslaq",
    "version": "1.0.0",
    "scheme": "openslaq",
    "platforms": [
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "com.openslaq.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
