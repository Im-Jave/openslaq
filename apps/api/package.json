{
  "name": "@openslack/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun --env-file=../../.env run --hot src/index.ts",
    "typecheck": "tsgo --noEmit",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env run src/db/migrate.ts",
    "db:seed": "bun --env-file=../../.env run src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^0.19.10",
    "@hono/zod-validator": "^0.4.3",
    "@openslack/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.9.44",
    "@stackframe/js": "^2.8.68",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.4",
    "jose": "^6.0.8",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3"
  }
}
