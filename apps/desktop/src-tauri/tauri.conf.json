{
  "productName": "OpenSlaq",
  "version": "0.0.1",
  "identifier": "com.openslaq.app",
  "build": {
    "beforeDevCommand": "cd ../web && bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../web && bun run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSlaq",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["openslaq"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyMTA5QzJFMDY3NzdEOUIKUldTYmZYY0dMcHdRRXFKTTRSbTQ0RzAwRjZOY2J1bHlRR3p2NEsrdFRmSzk4akZUVEZGU2doWmgK",
      "endpoints": [
        "https://github.com/openslaq/openslaq/releases/latest/download/latest.json"
      ]
    }
  }
}
