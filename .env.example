# API
API_PORT=3001
API_ARTIFICIAL_DELAY_MS=0
CORS_ORIGIN=http://localhost:3000,http://tauri.localhost,http://localhost:3007

# S3 (Bun reads S3_* env vars automatically)
S3_ENDPOINT=http://localhost:3003
S3_REGION=us-east-1
S3_BUCKET=openslaq-uploads
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_API_URL=http://localhost:3004
LIVEKIT_WS_URL=ws://localhost:3004

# Admin
ADMIN_USER_IDS=

# Frontend
